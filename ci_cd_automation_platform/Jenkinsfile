import groovy.json.JsonOutput

pipeline {
    agent any

    parameters {
        string(name: 'PROJECT_DIR', defaultValue: '.', description: 'Directory of the project to build/test (e.g. projects/allowed)')
    }

    environment {
        // Default values, will be overridden in stages if needed
        DOCKER_IMAGE_BASE = "deployed_app"
        PLATFORM_DIR = "ci_cd_automation_platform"
        PLATFORM_API = "https://jerold-nonimpressionistic-glynis.ngrok-free.dev"
        PIPELINE_ID  = "PL-${env.BUILD_ID}"
        PIPELINE_START_TIME = "${System.currentTimeMillis()}"
    }

    stages {
        stage('Stage 1: Checkout Code') {
            steps {
                script {
                    def stageStart = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                    try {
                        def scmVars = checkout scm
                        env.GIT_COMMIT = scmVars.GIT_COMMIT ?: bat(script: "@git rev-parse HEAD", returnStdout: true).trim()
                        env.GIT_BRANCH = scmVars.GIT_BRANCH ?: bat(script: "@git rev-parse --abbrev-ref HEAD", returnStdout: true).trim()
                        env.GIT_URL = scmVars.GIT_URL ?: bat(script: "@git config --get remote.origin.url", returnStdout: true).trim()
                        
                        // Capture author and message
                        env.GIT_AUTHOR = bat(script: "@git log -1 --pretty=format:%an", returnStdout: true).trim()
                        env.GIT_MESSAGE = bat(script: "@git log -1 --pretty=format:%s", returnStdout: true).trim()

                        def stageEnd = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                        
                        // First report includes metadata for correlation
                        def body = JsonOutput.toJson([
                            pipeline_id: env.PIPELINE_ID,
                            stage_checkout_start: stageStart,
                            stage_checkout_end: stageEnd,
                            stage_checkout_status: 'completed',
                            commit_id: env.GIT_COMMIT,
                            commit_author: env.GIT_AUTHOR,
                            commit_message: env.GIT_MESSAGE,
                            branch: env.GIT_BRANCH,
                            repository: env.GIT_URL,
                            status: 'running'
                        ])
                        sendReport(body)
                    } catch (err) {
                        def stageEnd = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                        reportStage('checkout', stageStart, stageEnd, 'failed')
                        throw err
                    }
                }
            }
        }

        stage('Stage 2: Install Dependencies') {
            steps {
                script {
                    def stageStart = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                    try {
                        bat """
                            cd ${env.PLATFORM_DIR}
                            python -m venv venv
                            venv\\\\Scripts\\\\pip install -r requirements.txt
                        """
                        def stageEnd = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                        reportStage('install', stageStart, stageEnd, 'completed')
                    } catch (err) {
                        def stageEnd = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                        reportStage('install', stageStart, stageEnd, 'failed')
                        throw err
                    }
                }
            }
        }

        stage('Stage 3: Run Tests') {
            steps {
                script {
                    env.TEST_STATUS = "PASSED"
                    env.TEST_LOG    = ""
                    def stageStart = new Date().format("yyyy-MM-dd'T'HH:mm:ss")

                    // Normalize and validate test path
                    def projectDir = params.PROJECT_DIR ?: "."
                    if (projectDir.startsWith(".")) {
                       // Strip leading dot if it's not just "."
                       if (projectDir.length() > 1 && projectDir[1] == '/') {
                           projectDir = projectDir.substring(2)
                       } else if (projectDir.length() > 1 && projectDir.startsWith(".projects")) {
                           projectDir = projectDir.substring(1) // .projects -> projects
                       }
                    }
                    
                    def testPath = "${projectDir}/tests/"
                    echo "Checking for tests at: ${env.PLATFORM_DIR}/${testPath}"
                    
                    def testsExist = fileExists("${env.PLATFORM_DIR}/${testPath}")
                    if (!testsExist) {
                        echo "Warning: ${testPath} not found. Falling back to default tests directory."
                        testPath = "tests/"
                    }

                    try {
                        bat """
                            cd ${env.PLATFORM_DIR}
                            venv\\\\Scripts\\\\python -m pytest ${testPath} -v > pytest_output.txt
                        """
                        env.TEST_LOG = readFile("${env.PLATFORM_DIR}/pytest_output.txt")
                    } catch (err) {
                        env.TEST_STATUS = "FAILED"
                        echo "Tests Failed: ${err}"
                        if (fileExists("${env.PLATFORM_DIR}/pytest_output.txt")) {
                            env.TEST_LOG = readFile("${env.PLATFORM_DIR}/pytest_output.txt")
                        } else {
                            env.TEST_LOG = "Fast-fail: Test directory missing or pytest failed to start."
                        }
                    }
                    def stageEnd = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                    def testStatus = env.TEST_STATUS == "PASSED" ? "completed" : "failed"

                    // Parse test counts safely using NonCPS helper
                    def counts = parsePytestOutput(env.TEST_LOG)
                    def passCount = counts.pass
                    def failCount = counts.fail
                    def skipCount = counts.skip

                    def body = JsonOutput.toJson([
                        pipeline_id: env.PIPELINE_ID,
                        stage_test_start: stageStart,
                        stage_test_end: stageEnd,
                        stage_test_status: testStatus,
                        test_pass_count: passCount,
                        test_fail_count: failCount,
                        test_skip_count: skipCount,
                        commit_id: env.GIT_COMMIT,
                        commit_author: env.GIT_AUTHOR,
                        commit_message: env.GIT_MESSAGE,
                        status: 'running'
                    ])

                    sendReport(body)

                    env.BUILD_DURATION = "0"
                    echo "Test Status: ${env.TEST_STATUS}"
                }
            }
        }

        stage('Stage 4: Collect Metrics') {
            steps {
                script {
                    def stageStart = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                    try {
                        def metricsResponse = httpRequest httpMode: 'GET',
                                                          url: "${env.PLATFORM_API}/api/metrics"
                        env.METRICS_DATA = metricsResponse.content
                        echo "Metrics collected: ${env.METRICS_DATA}"
                    } catch (err) {
                        echo "Warning: Failed to fetch metrics, using defaults: ${err}"
                        env.METRICS_DATA = '{"cpu": 0, "memory": 0, "disk": 0, "build_time": 0}'
                    }
                    def stageEnd = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                    reportStage('metrics', stageStart, stageEnd, 'completed')
                }
            }
        }

        stage('Stage 5: Evaluate Governance') {
            steps {
                script {
                    def stageStart = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                    try {
                        def metricsJson = env.METRICS_DATA ?: '{"cpu": 0, "memory": 0, "disk": 0, "build_time": 0}'
                        def response = httpRequest httpMode: 'POST',
                                                  contentType: 'APPLICATION_JSON',
                                                  requestBody: """{
                                                      "metrics": ${metricsJson},
                                                      "test_status": "${env.TEST_STATUS}",
                                                      "log_text": ${JsonOutput.toJson(env.TEST_LOG)}
                                                  }""",
                                                  url: "${env.PLATFORM_API}/api/evaluate"

                        def result = readJSON text: response.content

                        echo "Governance Decision: ${result.decision}"
                        echo "Waste Score: ${result.waste_score}"

                        def stageEnd = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                        def govStatus = result.decision == "BLOCK" ? "failed" : "completed"

                        def body = JsonOutput.toJson([
                            pipeline_id: env.PIPELINE_ID,
                            stage_governance_start: stageStart,
                            stage_governance_end: stageEnd,
                            stage_governance_status: govStatus,
                            governance_decision: result.decision,
                            governance_explanation: result.decision == "BLOCK" ?
                                "Deployment blocked: ${result.violations}" :
                                "All governance checks passed. Waste Score: ${result.waste_score}",
                            commit_id: env.GIT_COMMIT,
                            commit_author: env.GIT_AUTHOR,
                            commit_message: env.GIT_MESSAGE,
                            status: result.decision == "BLOCK" ? "blocked" : "running"
                        ])

                        sendReport(body)

                        if (result.decision == "BLOCK") {
                            error("Deployment BLOCKED by Governance Engine: ${result.violations}")
                        }
                    } catch (err) {
                        def stageEnd = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                        reportStage('governance', stageStart, stageEnd, 'failed')
                        throw err
                    }
                }
            }
        }

        stage('Stage 6: Build Docker Image') {
            steps {
                script {
                    def stageStart = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                    try {
                        def projectDir = params.PROJECT_DIR ?: "."
                        
                        // Normalize projectDir (remove leading ./ or leading . if followed by projects)
                        if (projectDir.startsWith("./")) {
                            projectDir = projectDir.substring(2)
                        } else if (projectDir.startsWith(".projects")) {
                            projectDir = projectDir.substring(1)
                        } else if (projectDir == ".") {
                            projectDir = ""
                        }
                        
                        env.PROJECT_NAME = projectDir ? projectDir.replaceAll("[^a-zA-Z0-9]", "_") : "root"
                        env.DOCKER_TAG = "${env.BUILD_ID}"
                        env.FULL_IMAGE_NAME = "${env.DOCKER_IMAGE_BASE}_${env.PROJECT_NAME}"

                        echo "Building Docker image for project in: ${env.PLATFORM_DIR}/${projectDir}"
                        
                        // Check if Dockerfile exists in project dir, if not use platform root's Dockerfile as fallback but with project context
                        def dockerfileDir = projectDir ?: "."
                        if (projectDir && !fileExists("${env.PLATFORM_DIR}/${projectDir}/Dockerfile")) {
                            echo "No Dockerfile found in ${projectDir}, using default from platform root."
                            dockerfileDir = "."
                        }

                        bat "cd ${env.PLATFORM_DIR} && docker build -t ${env.FULL_IMAGE_NAME}:${env.DOCKER_TAG} -f ${dockerfileDir}/Dockerfile ${projectDir ?: '.'}"
                        
                        def stageEnd = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                        reportStage('build', stageStart, stageEnd, 'completed')
                    } catch (err) {
                        def stageEnd = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                        reportStage('build', stageStart, stageEnd, 'failed')
                        throw err
                    }
                }
            }
        }

        stage('Stage 7: Deploy') {
            steps {
                script {
                    def stageStart = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                    try {
                        // Determine port based on project
                        def projectDir = params.PROJECT_DIR ?: "."
                        if (projectDir.startsWith("./")) {
                            projectDir = projectDir.substring(2)
                        } else if (projectDir.startsWith(".projects")) {
                            projectDir = projectDir.substring(1)
                        }

                        def deployPort = 6000
                        if (projectDir.contains("blocked")) deployPort = 7000
                        else if (projectDir.contains("allowed")) deployPort = 6000
                        else {
                            // Dynamic port for other projects to avoid collision
                            deployPort = 8000 + (env.BUILD_ID.toInteger() % 1000)
                        }

                        def containerName = "deployed_app_${env.PROJECT_NAME}"
                        
                        echo "Deploying ${env.FULL_IMAGE_NAME} to port ${deployPort}..."
                        bat "docker rm -f ${containerName} || true"
                        bat "docker run -d -p ${deployPort}:5000 --name ${containerName} ${env.FULL_IMAGE_NAME}:${env.DOCKER_TAG}"
                        
                        def stageEnd = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                        def deployedUrl = "http://localhost:${deployPort}"

                        def body = JsonOutput.toJson([
                            pipeline_id: env.PIPELINE_ID,
                            stage_deploy_start: stageStart,
                            stage_deploy_end: stageEnd,
                            stage_deploy_status: 'completed',
                            container_health: 'healthy',
                            deployed_port: deployPort,
                            deployed_url: deployedUrl,
                            total_pipeline_duration: (System.currentTimeMillis() - env.PIPELINE_START_TIME.toLong()) / 1000.0,
                            commit_id: env.GIT_COMMIT,
                            commit_author: env.GIT_AUTHOR,
                            commit_message: env.GIT_MESSAGE,
                            status: 'success'
                        ])

                        sendReport(body)
                    } catch (err) {
                        def stageEnd = new Date().format("yyyy-MM-dd'T'HH:mm:ss")
                        reportStage('deploy', stageStart, stageEnd, 'failed')
                        throw err
                    }
                }
            }
        }
    }
}

// Helper to report stage metadata to the platform API
def reportStage(stageName, startTime, endTime, status) {
    def body = JsonOutput.toJson([
        pipeline_id: env.PIPELINE_ID,
        ("stage_${stageName}_start".toString()): startTime,
        ("stage_${stageName}_end".toString()): endTime,
        ("stage_${stageName}_status".toString()): status,
        commit_id: env.GIT_COMMIT,
        commit_author: env.GIT_AUTHOR,
        commit_message: env.GIT_MESSAGE,
        repository: env.GIT_URL,
        branch: env.GIT_BRANCH,
        status: status == 'failed' ? 'failed' : 'running'
    ])
    sendReport(body)
}

@NonCPS
def parsePytestOutput(log) {
    def counts = [pass:0, fail:0, skip:0]
    if (!log) return counts
    
    // Check for 'passed'
    def pMatch = (log =~ /(\d+) passed/)
    if (pMatch.find()) counts.pass = pMatch.group(1).toInteger()
    
    // Check for 'failed'
    def fMatch = (log =~ /(\d+) failed/)
    if (fMatch.find()) counts.fail = fMatch.group(1).toInteger()
    
    // Check for 'skipped'
    def sMatch = (log =~ /(\d+) skipped/)
    if (sMatch.find()) counts.skip = sMatch.group(1).toInteger()
    
    return counts
}

def sendReport(body) {
    try {
        httpRequest httpMode: 'POST',
                    contentType: 'APPLICATION_JSON',
                    requestBody: body,
                    url: "${env.PLATFORM_API}/api/pipelines/report"
    } catch (e) {
        echo "API report failed: ${e}"
    }
}