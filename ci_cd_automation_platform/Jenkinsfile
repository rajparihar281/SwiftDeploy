pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "ci_cd_automation_platform"
        DOCKER_TAG   = "${env.BUILD_ID}"
        PLATFORM_DIR = "ci_cd_automation_platform"
    }

    stages {
        stage('Stage 1: Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Stage 2: Install Dependencies') {
            steps {
                script {
                    bat """
                        cd ${env.PLATFORM_DIR}
                        python -m venv venv
                        venv\\Scripts\\pip install -r requirements.txt
                    """
                }
            }
        }

        stage('Stage 3: Run Tests') {
            steps {
                script {
                    env.TEST_STATUS = "PASSED"
                    env.TEST_LOG    = ""
                    def startTime   = System.currentTimeMillis()

                    try {
                        // Capture the test output
                        bat """
                            cd ${env.PLATFORM_DIR}
                            venv\\Scripts\\python -m pytest tests/ -v > pytest_output.txt
                        """
                        env.TEST_LOG = readFile("${env.PLATFORM_DIR}/pytest_output.txt")
                    } catch (err) {
                        env.TEST_STATUS = "FAILED"
                        echo "Tests Failed: ${err}"
                        if (fileExists("${env.PLATFORM_DIR}/pytest_output.txt")) {
                            env.TEST_LOG = readFile("${env.PLATFORM_DIR}/pytest_output.txt")
                        }
                    }

                    def endTime = System.currentTimeMillis()
                    env.BUILD_DURATION = ((endTime - startTime) / 1000).toString()

                    echo "Build Duration (seconds): ${env.BUILD_DURATION}"
                    echo "Test Status: ${env.TEST_STATUS}"
                }
            }
        }

        stage('Stage 4: Collect Metrics') {
            steps {
                echo "Metrics collected: Build Duration = ${env.BUILD_DURATION}s, Test Status = ${env.TEST_STATUS}"
            }
        }

        stage('Stage 5: Evaluate Governance') {
            steps {
                script {
                    // Using httpRequest plugin which is cleaner than curl in bat
                    def response = httpRequest httpMode: 'POST', 
                                              contentType: 'APPLICATION_JSON', 
                                              requestBody: """{
                                                  "metrics": {
                                                      "cpu": 50,
                                                      "memory": 60,
                                                      "disk": 40,
                                                      "build_time": ${env.BUILD_DURATION}
                                                  },
                                                  "test_status": "${env.TEST_STATUS}",
                                                  "log_text": ${JsonOutput.toJson(env.TEST_LOG)}
                                              }""",
                                              url: "http://localhost:5000/api/evaluate"
                    
                    def result = readJSON text: response.content

                    echo "Governance Decision: ${result.decision}"
                    echo "Waste Score: ${result.waste_score}"

                    if (result.decision == "BLOCK") {
                        error("Deployment BLOCKED by Governance Engine: ${result.violations}")
                    }
                }
            }
        }

        stage('Stage 6: Build Docker Image') {
            steps {
                script {
                    bat "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ${env.PLATFORM_DIR}"
                }
            }
        }

        stage('Stage 7: Deploy') {
            steps {
                script {
                    echo "Deploying Docker container..."
                    // Kill existing container if exists
                    bat "docker rm -f ci_cd_app_demo || true"
                    bat "docker run -d -p 5050:5000 --name ci_cd_app_demo ${DOCKER_IMAGE}:${DOCKER_TAG}"
                }
            }
        }
    }
}

import groovy.json.JsonOutput